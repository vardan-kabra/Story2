# Copy this file to `.env.local` and fill in your key.
# Never commit `.env.local` — it is gitignored.

# Your Anthropic API key (https://console.anthropic.com/).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the Claude model (defaults to claude-opus-4-8).
# ASK_HR_MODEL=claude-opus-4-8

# Optional: override the SQLite database path (defaults to ./data/ask-hr.db).
# ASK_HR_DB_PATH=./data/ask-hr.db
